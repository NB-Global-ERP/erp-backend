# Project / container settings
PROJECT_NAME=erp-backend
CONTAINER_BACKEND_NAME=service
HOSTNAME_BACKEND=erp-service-host

# Postgres
CONTAINER_DB_NAME=erp-postgres
ERP_PG_HOST=erp-db-host          # используем hostname Postgres внутри сети
ERP_PG_PORT=5432
ERP_PG_DATABASE=erp_database
ERP_PG_USER=postgres
ERP_PG_PASSWORD=postgres

# Backend port
CONSENT_SERVICE_PORT=8080

# Flyway
CONTAINER_FLYWAY_NAME=erp-flyway